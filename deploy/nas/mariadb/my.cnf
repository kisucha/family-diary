# ============================================================================
# MariaDB 커스텀 설정 — NAS 환경 최적화
# 소규모 가족 앱 (5명 이하) 기준
# ============================================================================

[mysqld]

# ── 문자셋 ──────────────────────────────────────────────────────────────────
character-set-server            = utf8mb4
collation-server                = utf8mb4_unicode_ci
character-set-filesystem        = utf8mb4

# ── 타임존 ──────────────────────────────────────────────────────────────────
default_time_zone               = '+09:00'          # KST 고정

# ── InnoDB 설정 ─────────────────────────────────────────────────────────────
default_storage_engine          = InnoDB
innodb_buffer_pool_size         = 256M              # NAS RAM 1GB 기준 25% 할당
                                                    # RAM 2GB: 512M, RAM 4GB: 1G
innodb_log_file_size            = 64M
innodb_flush_log_at_trx_commit  = 2                 # 성능↑ (1초 내 데이터 손실 가능)
                                                    # 금융 앱이 아니므로 2 허용
innodb_flush_method             = O_DIRECT
innodb_file_per_table           = 1                 # 테이블별 독립 ibd 파일

# ── 연결 설정 ───────────────────────────────────────────────────────────────
max_connections                 = 20                # 가족 5명 + Prisma 커넥션 풀
connect_timeout                 = 10
wait_timeout                    = 600               # 유휴 연결 10분 후 종료
interactive_timeout             = 600

# ── 쿼리 캐시 (MariaDB 10.1 이하 유효, 10.2+ 비활성화 권장) ───────────────
query_cache_type                = 0
query_cache_size                = 0

# ── 바이너리 로그 (복구용, 백업 보완) ──────────────────────────────────────
log_bin                         = /var/lib/mysql/mariadb-bin
expire_logs_days                = 7                 # 7일 보관
max_binlog_size                 = 100M
binlog_format                   = ROW

# ── 슬로우 쿼리 로그 ───────────────────────────────────────────────────────
slow_query_log                  = 1
slow_query_log_file             = /var/lib/mysql/slow-queries.log
long_query_time                 = 2                 # 2초 이상 쿼리 기록

# ── 기타 ────────────────────────────────────────────────────────────────────
skip_name_resolve               = 1                 # DNS 역조회 비활성화 (성능↑)
sql_mode                        = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set           = utf8mb4

[mysql]
default-character-set           = utf8mb4
