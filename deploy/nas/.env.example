# ============================================================================
# Franklin Family Diary — NAS 환경변수 설정
# 사용법: cp .env.example .env 후 실제 값으로 교체
# 주의:  .env 파일은 절대 git에 커밋하지 말 것
# ============================================================================

# ----------------------------------------------------------------------------
# MariaDB 설정
# ----------------------------------------------------------------------------
DB_ROOT_PASSWORD=강력한_루트_비밀번호_여기에_입력   # 최소 20자 이상 권장
DB_NAME=family_planner
DB_USER=diary_app
DB_PASSWORD=강력한_앱_비밀번호_여기에_입력          # root와 다른 비밀번호 사용

# ----------------------------------------------------------------------------
# Next.js / NextAuth.js 설정
# ----------------------------------------------------------------------------
# 내부망에서만 쓰는 경우: http://NAS_IP (예: http://192.168.0.100)
# 외부 도메인 있는 경우:  https://diary.yourdomain.com
NEXTAUTH_URL=https://diary.yourdomain.com
NEXT_PUBLIC_APP_URL=https://diary.yourdomain.com

# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET=여기에_32바이트_랜덤_시크릿_입력

# ----------------------------------------------------------------------------
# Supabase Realtime (가족 공유 캘린더 실시간)
# Supabase 대시보드 > Project Settings > API 에서 확인
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# 도메인 / SSL 설정 (Nginx에서 참조)
# ----------------------------------------------------------------------------
# Cloudflare Tunnel 사용 시: 실제 도메인 입력
# DDNS 사용 시: your-family.duckdns.org 형식
# 내부망만 사용 시: NAS IP 주소
DOMAIN_NAME=diary.yourdomain.com
